    <!-- Analysis Methods (used in settings + onboarding) -->
    <string name="analysis_method_bmi_label">BMI</string>
    <string name="analysis_method_bmi_description">Setzt das Körpergewicht ins Verhältnis zur Körpergröße. Kein guter Indikator für Gesundheit, aber für viele Menschen eine nützliche erste Annäherung.</string>
    <string name="analysis_method_waist_hip_ratio_label">Taille-Hüft-Verhältnis</string>
    <string name="analysis_method_waist_hip_ratio_description">Berücksichtigt die Fettverteilung. Höhere Werte stehen mit einem erhöhten Risiko für Herz-Kreislauf- und Stoffwechselerkrankungen in Verbindung.</string>
    <string name="analysis_method_waist_height_ratio_label">Taille-Größe-Verhältnis</string>
    <string name="analysis_method_waist_height_ratio_description">Guter Indikator für kardiovaskuläre und metabolische Risiken, oft aussagekräftiger als der BMI.</string>
    <string name="analysis_method_navy_body_fat_label">Navy-Körperfett %</string>
    <string name="analysis_method_navy_body_fat_description">Schätzt den Körperfettanteil anhand von Messungen von Umfängen. Grobe Annäherung, aber sehr schnell zu messen.</string>
    <string name="analysis_method_skinfold_body_fat_label">Hautfalten-Körperfett %</string>
    <string name="analysis_method_skinfold_body_fat_description">Schätzt den Körperfettanteil anhand von Hautfaltenmessungen. Recht genau bei korrekter Durchführung, erfordert aber etwas Übung.</string>

