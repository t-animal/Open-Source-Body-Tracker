<resources>
    <string name="export_title">Export-Einstellungen</string>
    <string name="export_description">Deine Messungen, dein Profil und deine Fotos werden in ein verschlüsseltes ZIP-Archiv im gewählten Ordner exportiert. Nächtliche automatische Exports verwenden dasselbe Ziel und benötigen die Benachrichtigungsberechtigung, damit Android den Hintergrund-Export am Laufen halten kann.</string>
    <string name="export_password_description_prefix">Lege ein Passwort fest, um deine exportierten Daten zu verschlüsseln.  </string>
    <string name="export_password_description_bold">Du brauchst dieses Passwort, um deine Daten später zu importieren – bewahre es sicher auf! </string>
    <string name="export_password_description_suffix">Es gelten die üblichen Passwort-Sicherheitsregeln: Kein Wiederverwenden, lange und komplexe Passwörter sind am besten.</string>
    <string name="export_label_password">Verschlüsselungspasswort</string>
    <string name="export_label_device_storage">Auf Gerätespeicher exportieren</string>
    <string name="export_enable_password_hint">Gib ein Export-Passwort ein, um Export-Ziele zu aktivieren.</string>
    <string name="export_label_folder_prefix">Export-Ordner: </string>
    <string name="export_folder_not_set">Nicht festgelegt</string>
    <string name="export_button_select_folder">Ordner auswählen</string>
    <string name="export_label_automatic">Nächtliches automatisches Backup</string>
    <string name="export_automatic_description">Läuft gegen 3:00 Uhr, wenn sich Messungen geändert haben.</string>
    <string name="export_label_google_drive">Auf Google Drive exportieren (kommt später)</string>
    <string name="export_button_export_now">Jetzt exportieren</string>
