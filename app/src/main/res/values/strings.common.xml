    <!-- Analysis Methods (used in settings + onboarding) -->
    <string name="analysis_method_bmi_label">BMI</string>
    <string name="analysis_method_bmi_description">Puts body weight into relation to height. Not a good health indicator, but can be a useful first approximation for many people.</string>
    <string name="analysis_method_waist_hip_ratio_label">Waist–Hip Ratio</string>
    <string name="analysis_method_waist_hip_ratio_description">Accounts for fat distribution. Higher values are associated with increased risk of cardiovascular and metabolic diseases.</string>
    <string name="analysis_method_waist_height_ratio_label">Waist–Height Ratio</string>
    <string name="analysis_method_waist_height_ratio_description">Strong predictor of cardiovascular and metabolic risk, often more informative than BMI.</string>
    <string name="analysis_method_navy_body_fat_label">Navy Body Fat %</string>
    <string name="analysis_method_navy_body_fat_description">Estimates body fat percentage based on circumference measurements. Rough approximation and very quick to measure.</string>
    <string name="analysis_method_skinfold_body_fat_label">Skinfold Body Fat %</string>
    <string name="analysis_method_skinfold_body_fat_description">Estimates body fat percentage based on skinfold measurements. Quite accurate when done right, but requires some skill and practice.</string>

